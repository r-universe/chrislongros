[submodule ".registry"]
	path = .registry
	url = https://github.com/chrislongros/chrislongros.r-universe.dev
	branch = HEAD
[submodule "ankiR"]
	path = ankiR
	url = https://github.com/chrislongros/ankiR
[submodule "freebsdcontribs"]
	path = freebsdcontribs
	url = https://github.com/chrislongros/freebsdcontribs
[submodule "osscontribs"]
	path = osscontribs
	url = https://github.com/chrislongros/osscontribs
[submodule "rfsrs"]
	path = rfsrs
	url = https://github.com/open-spaced-repetition/r-fsrs
	branch = master
[submodule "srsbench"]
	path = srsbench
	url = https://github.com/chrislongros/srsbench
